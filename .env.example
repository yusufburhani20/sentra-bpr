# SIM-SLIP-REF Environment Configurations
PORT=3000
NODE_ENV=development

# ⚠️  WAJIB DIGANTI di produksi! Gunakan string acak panjang minimal 32 karakter.
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=SIM_SLIP_REF_SECRET_2026_GANTI_DI_PRODUKSI

# Database selection: 'sqlite' or 'postgres'
DB_TYPE=sqlite

# PostgreSQL Connection Details (Used only when DB_TYPE=postgres)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=yourpassword
PGDATABASE=sim_slip_ref

# CORS: Domain yang diizinkan mengakses API (pisahkan dengan koma)
# Di produksi, isi dengan domain resmi aplikasi saja.
ALLOWED_ORIGINS=http://localhost:3000,http://slip.nusambasingaparna.com

# File Backup Path (contoh untuk server linux)
BACKUP_FOLDER_PATH=/mnt/backup_windows
